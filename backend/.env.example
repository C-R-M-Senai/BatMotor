# Copie para .env (não committe o .env com segredos reais).

DATABASE_URL="mysql://batmotouser:batmotopass@localhost:3307/backend_db"
SHADOW_DATABASE_URL="mysql://root:rootpass@localhost:3307/backend_db"

DATABASE_HOST=localhost
DATABASE_PORT=3307
DATABASE_USER=batmotouser
DATABASE_PASSWORD=batmotopass
DATABASE_NAME=backend_db

# JWT: segredo para assinar tokens (≠ token Bearer; esse vem do POST /auth/login após credenciais válidas).
# Exemplo didático — em produção use valor longo e aleatório.
JWT_SECRET="adminbatmoto_segredo_batmotor_jwt_dev"
JWT_EXPIRES_IN="8h"

# Opcional
# PORT=3000
