# Copie para .env (não committe o .env com segredos reais).
#
# Se você mudou MYSQL_DATABASE ou já existia volume com outro nome de banco:
#   docker compose down -v && docker compose up -d
# Depois: npx prisma migrate deploy  (ou migrate dev em desenvolvimento).
# Primeiro login dev (admin@batmotor.com / adminbatmotor): npx prisma db seed  ou  npm run db:seed

DATABASE_URL="mysql://batmotouser:batmotopass@localhost:3307/batmotor_db"
SHADOW_DATABASE_URL="mysql://root:rootpass@localhost:3307/batmotor_shadow"

DATABASE_HOST=localhost
DATABASE_PORT=3307
DATABASE_USER=batmotouser
DATABASE_PASSWORD=batmotopass
DATABASE_NAME=batmotor_db

# JWT: segredo para assinar tokens (≠ token Bearer; esse vem do POST /auth/login após credenciais válidas).
# Exemplo didático — em produção use valor longo e aleatório.
JWT_SECRET="adminbatmoto_segredo_batmotor_jwt_dev"
JWT_EXPIRES_IN="8h"

# Opcional
# PORT=3000
