# Copie para .env e ajuste. Não commite o .env com segredos reais da empresa.
#
# Variáveis MYSQL_* são lidas pelo docker-compose.yml na mesma pasta.
# Depois de subir o MySQL: npx prisma migrate deploy
# Usuário inicial de dev: npx prisma db seed (e-mail/senha em prisma/seed.ts, só local).

MYSQL_ROOT_PASSWORD=dev_root_altere
MYSQL_DATABASE=app_db
MYSQL_USER=app_user
MYSQL_PASSWORD=dev_app_altere
MYSQL_PORT_HOST=3307

DATABASE_URL="mysql://app_user:dev_app_altere@localhost:3307/app_db"
SHADOW_DATABASE_URL="mysql://root:dev_root_altere@localhost:3307/prisma_migrate_shadow"

DATABASE_HOST=localhost
DATABASE_PORT=3307
DATABASE_USER=app_user
DATABASE_PASSWORD=dev_app_altere
DATABASE_NAME=app_db

JWT_SECRET="ALTERE_GERE_STRING_LONGA_ALEATORIA"
JWT_EXPIRES_IN="8h"

# Opcional
# PORT=3000
