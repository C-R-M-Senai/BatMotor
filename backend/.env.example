# Copie para .env e ajuste se necessário.
# MySQL do Docker em localhost:3307 (evita conflito com MySQL local na 3306).

DATABASE_URL="mysql://batmotouser:batmotopass@localhost:3307/backend_db"
SHADOW_DATABASE_URL="mysql://root:rootpass@localhost:3307/backend_db"

DATABASE_HOST=localhost
DATABASE_USER=batmotouser
DATABASE_PASSWORD=batmotopass
DATABASE_NAME=backend_db
DATABASE_PORT=3307

# Só se o MySQL já existia sem o script docker/mysql-init (volume antigo) e migrate falhar no shadow DB:
# SHADOW_DATABASE_URL="mysql://root:rootpass@localhost:3307/mysql"

