# Copie para `.env` na mesma pasta (o `.env` não vai para o Git).
# Depois: docker compose up -d → npx prisma migrate deploy → npx prisma db seed

MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=batmotor_db
MYSQL_USER=batmotouser
MYSQL_PASSWORD=batmotopass
MYSQL_PORT_HOST=3307

# MySQL 8: use ?allowPublicKeyRetrieval=true e prefira 127.0.0.1 no Windows (evita P1017 / handshake).
DATABASE_URL="mysql://batmotouser:batmotopass@127.0.0.1:3307/batmotor_db?allowPublicKeyRetrieval=true"
SHADOW_DATABASE_URL="mysql://root:rootpass@127.0.0.1:3307/batmotor_shadow?allowPublicKeyRetrieval=true"

DATABASE_HOST=127.0.0.1
DATABASE_PORT=3307
DATABASE_USER=batmotouser
DATABASE_PASSWORD=batmotopass
DATABASE_NAME=batmotor_db

JWT_SECRET="ALTERE_GERE_STRING_LONGA_ALEATORIA"
JWT_EXPIRES_IN="8h"

# Opcional
# PORT=3000
