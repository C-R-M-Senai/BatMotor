# =============================================================================
# BatMotor front (MongoDB stack) — Vite
# Copia para .env ou define no Render (Build Environment) antes do npm run build
# =============================================================================

# --- URL da API (backend_mongoDB) ---
# Desenvolvimento local:
VITE_API_URL=http://localhost:3000
#
# Produção (Render, etc.): HTTPS da Web Service, SEM barra no fim.
# Exemplo:
# VITE_API_URL=https://batmotor-api-mongodb-xxxx.onrender.com

# false = chamadas reais ao backend; true = dados mock (sem rede)
VITE_USE_MOCK=false

# Opcional: cadastro gestor (se o backend usar o mesmo token)
# VITE_MANAGER_REGISTRATION_TOKEN=batmotor-gestor-dev
