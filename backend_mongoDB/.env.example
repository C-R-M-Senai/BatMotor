# MongoDB (obrigatório para este backend)
MONGODB_URI=mongodb://127.0.0.1:27017/batmotor

# API
PORT=3000

# JWT
JWT_SECRET=troque_por_string_longa_e_aleatoria
JWT_EXPIRES_IN=8h

# Saídas de estoque >= valor exigem ADMIN ou GERENTE (padrão 500)
# LARGE_OUT_THRESHOLD=500

# CORS: origens extra (vírgula). Locais (5173/4173) já vêm por defeito; aqui coloca o URL do front no Render.
# Exemplo (troca pelo teu site estático real):
# CORS_ORIGINS=https://batmotor-frontend-xxxx.onrender.com

# E-mail alertas (opcional)
# SMTP_HOST=
# SMTP_PORT=587
# ALERT_EMAIL_TO=
